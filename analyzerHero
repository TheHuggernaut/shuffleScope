// UI RENDERING
// ============================================================

let rounds = [];
let currentRound = null;

function renderSidebar() {
  const list = document.getElementById('rounds-list');
  list.innerHTML = '';

  rounds.forEach((round, i) => {
    const score = round.score;
    const cls = score >= 80 ? 'good' : score >= 60 ? 'mid' : 'bad';
    const duration = round.duration ? fmtTime(round.duration) : '—';
    const players = Object.values(round.players);
    const specNames = [...new Set(players.map(p => p.spec).filter(s => s !== 'Unknown'))].slice(0,3).join(', ') || 'Unknown specs';

    const el = document.createElement('div');
    el.className = 'round-item' + (i === 0 ? ' active' : '');
    el.innerHTML = `
      <div class="round-num">R${round.index}</div>
      <div class="round-meta">
        <div class="round-title">${round.demoLabel || 'Round ' + round.index}</div>
        <div class="round-stats">${duration} · ${round.mistakes.length} issue${round.mistakes.length !== 1 ? 's' : ''}</div>
      </div>
      <div class="round-score">
        <div class="score-badge score-${cls}">${score}</div>
      </div>
    `;
    el.onclick = () => {
      document.querySelectorAll('.round-item').forEach(e => e.classList.remove('active'));
      el.classList.add('active');
      renderRound(round);
    };
    list.appendChild(el);
  });

  // Summary
  const avgScore = Math.round(rounds.reduce((a,r) => a + r.score, 0) / rounds.length);
  const totalMistakes = rounds.reduce((a,r) => a + r.mistakes.length, 0);
  const highMistakes = rounds.reduce((a,r) => a + r.mistakes.filter(m=>m.severity==='HIGH').length, 0);
  document.getElementById('sidebar-summary').innerHTML = `
    <div class="summary-row"><span>Avg Score</span><span>${avgScore}/100</span></div>
    <div class="summary-row"><span>Total Issues</span><span>${totalMistakes}</span></div>
    <div class="summary-row"><span>Critical</span><span style="color:var(--red2)">${highMistakes}</span></div>
  `;
}

function renderRound(round) {
  currentRound = round;
  const panel = document.getElementById('main-panel');
  const score = round.score;
  const scoreCls = score >= 80 ? 'good' : score >= 60 ? 'mid' : 'bad';
  const duration = round.duration ? fmtTime(round.duration) : '—';
  const players = Object.values(round.players);
  const totalDmg = players.reduce((a,p) => a+p.dmgOut, 0);
  const ccEvents = round.events.filter(e => e.type === 'CC').length;
  const drViolations = round.events.filter(e => e.flag).length;
  const deaths = round.events.filter(e => e.type === 'DEATH').length;

  panel.innerHTML = `
    <div class="round-header">
      <div>
        <div class="round-header-title">${round.demoLabel || 'Round ' + round.index}</div>
        <div class="round-header-sub">Duration: ${duration} · ${ccEvents} CC events · ${drViolations} DR flag${drViolations !== 1 ? 's' : ''} · ${deaths} death${deaths !== 1 ? 's' : ''}</div>
      </div>
      <div class="round-header-score">
        <div class="big-score ${scoreCls}">${score}</div>
        <div class="big-score-label">Performance Score</div>
      </div>
    </div>

    <div class="cards-row">
      <div class="stat-card">
        <div class="stat-label">CC Applied</div>
        <div class="stat-value">${ccEvents}</div>
        <div class="stat-delta delta-neutral">this round</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">DR Violations</div>
        <div class="stat-value" style="color:${drViolations>0?'var(--red2)':'var(--green2)'}">${drViolations}</div>
        <div class="stat-delta ${drViolations>0?'delta-bad':'delta-good'}">${drViolations>0?'needs attention':'clean'}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Issues Found</div>
        <div class="stat-value">${round.mistakes.length}</div>
        <div class="stat-delta ${round.mistakes.filter(m=>m.severity==='HIGH').length>0?'delta-bad':'delta-neutral'}">${round.mistakes.filter(m=>m.severity==='HIGH').length} critical</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Cooldowns Used</div>
        <div class="stat-value">${round.events.filter(e=>e.type==='COOLDOWN').length}</div>
        <div class="stat-delta delta-neutral">tracked abilities</div>
      </div>
    </div>

    ${renderTimeline(round)}
    ${renderMistakes(round)}
    ${renderEventLog(round)}
    ${renderPlayerBreakdown(round)}
  `;
}

function renderTimeline(round) {
  if (!round.duration || round.events.length === 0) return '';
  const dur = round.duration;
  const pct = t => ((t / dur) * 100).toFixed(2) + '%';
  const wPct = (t, w) => Math.max(0.5, ((w / dur) * 100)).toFixed(2) + '%';

  const ccHtml = round.events.filter(e=>e.type==='CC').map(e => {
    const w = 12000 / dur * 100;
    return `<div class="tl-event tl-cc" style="left:${pct(e.relTime)};width:${Math.max(0.8,w).toFixed(2)}%" title="${e.spell}"></div>`;
  }).join('');

  const cdHtml = round.events.filter(e=>e.type==='COOLDOWN').map(e => {
    const w = 15000 / dur * 100;
    return `<div class="tl-event tl-cd" style="left:${pct(e.relTime)};width:${Math.max(0.8,w).toFixed(2)}%" title="${e.spell}"></div>`;
  }).join('');

  const deathHtml = round.events.filter(e=>e.type==='DEATH').map(e =>
    `<div class="tl-event tl-death" style="left:${pct(e.relTime)}" title="${e.source} died"></div>`
  ).join('');

  // Ruler
  const tickCount = Math.min(10, Math.floor(dur / 10000));
  const tickInterval = dur / tickCount;
  let rulerHtml = '';
  for (let i = 0; i <= tickCount; i++) {
    const t = i * tickInterval;
    rulerHtml += `<div class="ruler-line" style="left:${pct(t)}"></div>`;
    rulerHtml += `<div class="ruler-tick" style="left:${pct(t)}">${fmtTime(t)}</div>`;
  }

  return `
    <div class="section" style="margin-bottom:16px">
      <div class="section-header">
        <span class="section-title">Round Timeline</span>
        <span class="section-badge" style="background:rgba(155,111,212,0.15);color:#c4a0ff;border-color:rgba(155,111,212,0.3)">■ CC</span>
        <span class="section-badge" style="background:rgba(201,168,76,0.15);color:var(--gold2);border-color:rgba(201,168,76,0.3)">■ CD</span>
        <span class="section-badge" style="background:rgba(212,88,88,0.4);color:#fff;border-color:var(--red)">■ Death</span>
      </div>
      <div class="section-body">
        <div class="timeline-label">Crowd Control</div>
        <div class="timeline-track">${ccHtml}${deathHtml}</div>
        <div class="timeline-label">Cooldowns</div>
        <div class="timeline-track">${cdHtml}${deathHtml}</div>
        <div class="timeline-ruler">${rulerHtml}</div>
      </div>
    </div>
  `;
}

function renderMistakes(round) {
  if (!round.mistakes.length) {
    return `<div class="section" style="margin-bottom:16px">
      <div class="section-header"><span class="section-title">Issue Report</span><span class="section-badge score-good" style="background:rgba(76,175,125,0.15);color:var(--green2);border:1px solid rgba(76,175,125,0.3)">Clean round</span></div>
      <div class="section-body"><div style="color:var(--green2);font-size:13px">No significant issues detected this round.</div></div>
    </div>`;
  }

  const items = round.mistakes.map(m => `
    <div class="mistake-item">
      <div>
        <div class="mistake-sev sev-${m.severity.toLowerCase()}">${m.severity}</div>
        <div class="mistake-at">${m.at}</div>
      </div>
      <div class="mistake-body">
        <div class="mistake-title">${m.title}</div>
        <div class="mistake-desc">${m.desc}</div>
        <div class="mistake-tip">▸ ${m.tip}</div>
      </div>
    </div>
  `).join('');

  return `
    <div class="section" style="margin-bottom:16px">
      <div class="section-header">
        <span class="section-title">Issue Report</span>
        <span class="section-badge">${round.mistakes.length} issue${round.mistakes.length!==1?'s':''}</span>
        <span style="margin-left:auto;font-size:11px;color:var(--text2)">${round.mistakes.filter(m=>m.severity==='HIGH').length} critical · ${round.mistakes.filter(m=>m.severity==='MEDIUM').length} medium · ${round.mistakes.filter(m=>m.severity==='LOW').length} low</span>
      </div>
      <div>${items}</div>
    </div>
  `;
}

function renderEventLog(round) {
  const sorted = [...round.events].sort((a,b) => a.relTime - b.relTime);
  const rows = sorted.map(e => {
    const typeMap = { CC:'tag-cc CC', COOLDOWN:'tag-cooldown CD', DEATH:'tag-death DEATH', SWAP:'tag-swap SWAP', DR:'tag-dr DR' };
    const [cls, label] = (typeMap[e.type] || 'tag-cc ???').split(' ');
    const rowCls = e.flag ? 'flagged' : e.positive ? 'positive' : '';
    return `
      <div class="event-row ${rowCls}">
        <div class="event-time">${fmtTime(e.relTime)}</div>
        <div class="event-type-tag ${cls}">${label}</div>
        <div class="event-desc">${e.desc}${e.drCategory?` <span style="color:var(--text2);font-size:11px">[${e.drCategory}]</span>`:''}${e.drMultiplier!==undefined&&e.drMultiplier<1?` <span style="color:var(--orange);font-size:11px">×${e.drMultiplier}</span>`:''}</div>
        ${e.flag ? `<div class="event-flag">${e.flag}</div>` : ''}
      </div>
    `;
  }).join('');

  return `
    <div class="section" style="margin-bottom:16px">
      <div class="section-header">
        <span class="section-title">Event Log</span>
        <span class="section-badge">${sorted.length} events</span>
      </div>
      <div class="section-body">
        <div class="events-list">${rows || '<div style="color:var(--text2)">No events detected.</div>'}</div>
      </div>
    </div>
  `;
}

function renderPlayerBreakdown(round) {
  const players = Object.values(round.players);
  if (!players.length) return '';

  const maxDmg = Math.max(...players.map(p=>p.dmgOut)) || 1;

  const rows = players.sort((a,b) => b.dmgOut - a.dmgOut).map(p => {
    const pct = Math.round((p.dmgOut / maxDmg) * 100);
    const color = p.deathCount > 0 ? 'var(--red)' : 'var(--accent)';
    return `
      <div class="player-row">
        <div class="player-spec">${p.name}<br><span style="font-size:10px;color:var(--text2);font-weight:400">${p.spec}</span></div>
        <div class="player-bar-wrap">
          <div class="player-bar-bg">
            <div class="player-bar-fill" style="width:${pct}%;background:${color}"></div>
          </div>
        </div>
        <div class="player-value">${p.dmgOut ? (p.dmgOut/1000).toFixed(0)+'k' : '—'}</div>
        <div style="min-width:32px;text-align:right;font-size:11px;color:var(--purple)">${p.ccApplied} cc</div>
        ${p.deathCount ? `<div style="min-width:28px;font-size:11px;color:var(--red2);text-align:right">☠ ${p.deathCount}</div>` : '<div style="min-width:28px"></div>'}
      </div>
    `;
  }).join('');

  return `
    <div class="section">
      <div class="section-header">
        <span class="section-title">Player Breakdown</span>
        <span class="section-badge">${players.length} players</span>
      </div>
      <div class="section-body">${rows}</div>
    </div>
  `;
}

