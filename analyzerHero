<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShuffleScope — WoW PvP Analyzer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg0: #0a0c10;
  --bg1: #0f1219;
  --bg2: #151820;
  --bg3: #1c2130;
  --border: #252d3d;
  --border2: #2e3850;
  --text0: #e8ecf4;
  --text1: #9aa3b8;
  --text2: #5c6680;
  --accent: #4fa3e0;
  --accent2: #2d7ab5;
  --gold: #c9a84c;
  --gold2: #e8c76a;
  --red: #d45858;
  --red2: #e87070;
  --green: #4caf7d;
  --green2: #68cc96;
  --orange: #d4884a;
  --purple: #9b6fd4;
  --font-mono: 'Share Tech Mono', monospace;
  --font-body: 'Barlow', sans-serif;
  --font-cond: 'Barlow Condensed', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg0);
  color: var(--text0);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
}

/* HEADER */
header {
  background: var(--bg1);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  height: 52px;
  display: flex;
  align-items: center;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  font-family: var(--font-cond);
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--gold2);
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 8px;
}
.logo-icon {
  width: 22px; height: 22px;
  background: var(--gold);
  clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
  display: inline-block;
}
.logo-sub {
  font-size: 11px;
  font-weight: 500;
  color: var(--text2);
  letter-spacing: 0.15em;
  border-left: 1px solid var(--border2);
  padding-left: 16px;
  margin-left: 8px;
}

.header-actions { margin-left: auto; display: flex; gap: 8px; align-items: center; }

.btn {
  font-family: var(--font-cond);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 16px;
  border-radius: 3px;
  border: 1px solid var(--border2);
  background: var(--bg3);
  color: var(--text1);
  cursor: pointer;
  transition: all 0.15s;
}
.btn:hover { border-color: var(--accent2); color: var(--accent); background: rgba(79,163,224,0.06); }
.btn.primary {
  background: var(--accent2);
  border-color: var(--accent);
  color: #fff;
}
.btn.primary:hover { background: var(--accent); }

/* LANDING */
#landing {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 52px);
  padding: 40px 24px;
  position: relative;
  overflow: hidden;
}
#landing::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 40%, rgba(79,163,224,0.04) 0%, transparent 70%);
  pointer-events: none;
}

.drop-zone {
  width: 100%;
  max-width: 560px;
  border: 1px dashed var(--border2);
  border-radius: 6px;
  padding: 60px 40px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--bg1);
  position: relative;
}
.drop-zone:hover, .drop-zone.drag-over {
  border-color: var(--accent);
  background: rgba(79,163,224,0.04);
}
.drop-zone input[type=file] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
.drop-icon {
  font-size: 40px;
  margin-bottom: 16px;
  opacity: 0.4;
}
.drop-title {
  font-family: var(--font-cond);
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--text0);
  margin-bottom: 8px;
}
.drop-sub {
  font-size: 13px;
  color: var(--text2);
  margin-bottom: 20px;
}
.drop-hint {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text2);
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 4px 12px;
  display: inline-block;
}

.demo-link {
  margin-top: 24px;
  font-size: 13px;
  color: var(--text2);
}
.demo-link a {
  color: var(--accent2);
  cursor: pointer;
  text-decoration: underline;
}
.demo-link a:hover { color: var(--accent); }

.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  max-width: 560px;
  width: 100%;
  margin-top: 40px;
}
.feature-card {
  background: var(--bg1);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 14px 16px;
}
.feature-card .fc-label {
  font-family: var(--font-cond);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 4px;
}
.feature-card .fc-desc {
  font-size: 12px;
  color: var(--text1);
  line-height: 1.4;
}

/* MAIN LAYOUT */
#app { display: none; height: calc(100vh - 52px); overflow: hidden; }
#app.visible { display: flex; }

/* SIDEBAR */
.sidebar {
  width: 260px;
  min-width: 260px;
  background: var(--bg1);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}
.sidebar-header {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  font-family: var(--font-cond);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text2);
}
.round-item {
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.1s;
  display: flex;
  align-items: center;
  gap: 10px;
}
.round-item:hover { background: var(--bg2); }
.round-item.active { background: var(--bg3); border-left: 2px solid var(--accent); }
.round-num {
  font-family: var(--font-cond);
  font-size: 18px;
  font-weight: 700;
  color: var(--text2);
  min-width: 24px;
}
.round-item.active .round-num { color: var(--accent); }
.round-meta { flex: 1; min-width: 0; }
.round-title {
  font-size: 13px;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.round-stats { font-size: 11px; color: var(--text2); margin-top: 2px; }
.round-score {
  display: flex;
  align-items: center;
  gap: 4px;
}
.score-badge {
  font-family: var(--font-cond);
  font-size: 14px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 2px;
  min-width: 34px;
  text-align: center;
}
.score-good { background: rgba(76,175,125,0.15); color: var(--green2); }
.score-mid  { background: rgba(201,168,76,0.15); color: var(--gold2); }
.score-bad  { background: rgba(212,88,88,0.15); color: var(--red2); }

.sidebar-summary {
  padding: 14px 16px;
  border-top: 1px solid var(--border);
  margin-top: auto;
  background: var(--bg0);
}
.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text2);
  margin-bottom: 4px;
}
.summary-row span:last-child { color: var(--text0); font-weight: 500; }

/* MAIN PANEL */
.main-panel {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
  background: var(--bg0);
}

/* ROUND HEADER */
.round-header {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 24px;
}
.round-header-title {
  font-family: var(--font-cond);
  font-size: 28px;
  font-weight: 700;
  letter-spacing: 0.04em;
}
.round-header-sub {
  font-size: 13px;
  color: var(--text1);
  margin-top: 2px;
}
.round-header-score {
  margin-left: auto;
  text-align: right;
}
.big-score {
  font-family: var(--font-cond);
  font-size: 48px;
  font-weight: 700;
  line-height: 1;
}
.big-score.good { color: var(--green2); }
.big-score.mid  { color: var(--gold2); }
.big-score.bad  { color: var(--red2); }
.big-score-label { font-size: 11px; color: var(--text2); letter-spacing: 0.1em; text-transform: uppercase; }

/* CARDS */
.cards-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}
.stat-card {
  background: var(--bg1);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 12px 14px;
}
.stat-label {
  font-family: var(--font-cond);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text2);
  margin-bottom: 4px;
}
.stat-value {
  font-family: var(--font-cond);
  font-size: 22px;
  font-weight: 700;
  color: var(--text0);
}
.stat-delta {
  font-size: 11px;
  margin-top: 2px;
}
.delta-bad { color: var(--red); }
.delta-good { color: var(--green); }
.delta-neutral { color: var(--text2); }

/* SECTION */
.section {
  background: var(--bg1);
  border: 1px solid var(--border);
  border-radius: 4px;
  margin-bottom: 16px;
  overflow: hidden;
}
.section-header {
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-title {
  font-family: var(--font-cond);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text1);
}
.section-badge {
  font-family: var(--font-cond);
  font-size: 11px;
  font-weight: 600;
  padding: 1px 6px;
  border-radius: 2px;
  background: var(--bg3);
  color: var(--text2);
  border: 1px solid var(--border2);
}
.section-body { padding: 14px 16px; }

/* TIMELINE */
.timeline { position: relative; }
.timeline-track {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 3px;
  height: 36px;
  position: relative;
  overflow: hidden;
  margin-bottom: 8px;
  cursor: pointer;
}
.timeline-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text2);
  margin-bottom: 4px;
}
.tl-event {
  position: absolute;
  top: 4px;
  height: 28px;
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 600;
  overflow: hidden;
  cursor: pointer;
  transition: filter 0.1s;
  min-width: 4px;
}
.tl-event:hover { filter: brightness(1.3); }
.tl-cc { background: rgba(155,111,212,0.7); border: 1px solid var(--purple); color: #d4b8ff; }
.tl-cd { background: rgba(201,168,76,0.7); border: 1px solid var(--gold); color: #ffe89b; }
.tl-swap { background: rgba(79,163,224,0.6); border: 1px solid var(--accent); color: #b8dfff; }
.tl-dmg { background: rgba(212,88,88,0.5); border: 1px solid var(--red); color: #ffb8b8; }
.tl-death { background: var(--red); border: 1px solid #ff4040; width: 3px !important; min-width: 3px; }
.tl-win { background: var(--green); border: 1px solid var(--green2); width: 3px !important; min-width: 3px; }
.timeline-ruler {
  height: 16px;
  position: relative;
  margin-bottom: 12px;
}
.ruler-tick {
  position: absolute;
  bottom: 0;
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text2);
  transform: translateX(-50%);
}
.ruler-line {
  position: absolute;
  bottom: 10px;
  width: 1px;
  height: 4px;
  background: var(--border2);
  transform: translateX(-50%);
}

/* EVENTS LIST */
.events-list { display: flex; flex-direction: column; gap: 2px; }
.event-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 7px 10px;
  border-radius: 3px;
  border: 1px solid transparent;
  transition: background 0.1s;
}
.event-row:hover { background: var(--bg2); border-color: var(--border); }
.event-row.flagged {
  background: rgba(212,88,88,0.05);
  border-color: rgba(212,88,88,0.2);
}
.event-row.positive {
  background: rgba(76,175,125,0.05);
  border-color: rgba(76,175,125,0.2);
}
.event-time {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text2);
  min-width: 40px;
  padding-top: 1px;
}
.event-type-tag {
  font-family: var(--font-cond);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 1px 6px;
  border-radius: 2px;
  min-width: 54px;
  text-align: center;
}
.tag-cc       { background: rgba(155,111,212,0.2); color: #c4a0ff; border: 1px solid rgba(155,111,212,0.3); }
.tag-cooldown { background: rgba(201,168,76,0.2);  color: var(--gold2); border: 1px solid rgba(201,168,76,0.3); }
.tag-swap     { background: rgba(79,163,224,0.2);  color: #90cdf4; border: 1px solid rgba(79,163,224,0.3); }
.tag-damage   { background: rgba(212,88,88,0.2);   color: var(--red2); border: 1px solid rgba(212,88,88,0.3); }
.tag-dr       { background: rgba(212,136,74,0.2);  color: #ffbb80; border: 1px solid rgba(212,136,74,0.3); }
.tag-death    { background: rgba(212,88,88,0.4);   color: #fff; border: 1px solid var(--red); }
.event-desc { flex: 1; font-size: 13px; color: var(--text0); }
.event-flag {
  font-size: 11px;
  color: var(--red2);
  background: rgba(212,88,88,0.1);
  border: 1px solid rgba(212,88,88,0.2);
  border-radius: 2px;
  padding: 1px 6px;
}
.event-pos {
  font-size: 11px;
  color: var(--green2);
  background: rgba(76,175,125,0.1);
  border: 1px solid rgba(76,175,125,0.2);
  border-radius: 2px;
  padding: 1px 6px;
}

/* MISTAKES */
.mistake-item {
  padding: 12px 14px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.mistake-item:last-child { border-bottom: none; }
.mistake-sev {
  font-family: var(--font-cond);
  font-size: 11px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 2px;
  min-width: 40px;
  text-align: center;
  margin-top: 1px;
}
.sev-high   { background: rgba(212,88,88,0.2);   color: var(--red2);   border: 1px solid rgba(212,88,88,0.4); }
.sev-medium { background: rgba(212,136,74,0.2);  color: #ffbb80;       border: 1px solid rgba(212,136,74,0.4); }
.sev-low    { background: rgba(201,168,76,0.15); color: var(--gold);   border: 1px solid rgba(201,168,76,0.3); }
.mistake-body { flex: 1; }
.mistake-title { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
.mistake-desc  { font-size: 12px; color: var(--text1); line-height: 1.4; }
.mistake-tip {
  margin-top: 6px;
  font-size: 12px;
  color: var(--accent);
  padding-left: 10px;
  border-left: 2px solid var(--accent2);
}
.mistake-at {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text2);
  margin-top: 1px;
  white-space: nowrap;
}

/* PLAYER BREAKDOWN */
.player-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.player-row:last-child { border-bottom: none; }
.player-spec {
  font-family: var(--font-cond);
  font-size: 12px;
  font-weight: 600;
  width: 120px;
  color: var(--text1);
}
.player-bar-wrap { flex: 1; }
.player-bar-bg {
  height: 6px;
  background: var(--bg3);
  border-radius: 3px;
  overflow: hidden;
}
.player-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.5s ease;
}
.player-value {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text1);
  min-width: 52px;
  text-align: right;
}

/* PROGRESS / LOADING */
#loading-screen {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 52px);
  gap: 16px;
}
.loading-bar-wrap {
  width: 320px;
  height: 4px;
  background: var(--bg2);
  border-radius: 2px;
  overflow: hidden;
}
.loading-bar {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  transition: width 0.3s ease;
  width: 0%;
}
.loading-text {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text2);
}

/* SCROLLBAR */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg1); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

/* TOOLTIP */
.tooltip {
  position: fixed;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 4px;
  padding: 8px 12px;
  font-size: 12px;
  color: var(--text0);
  pointer-events: none;
  z-index: 999;
  display: none;
  max-width: 240px;
  line-height: 1.4;
}

/* empty state */
.empty-state {
  text-align: center;
  padding: 40px;
  color: var(--text2);
  font-size: 13px;
}
</style>
</head>
<body>

<header>
  <div class="logo">
    <span class="logo-icon"></span>
    ShuffleScope
    <span class="logo-sub">PvP Combat Analyzer</span>
  </div>
  <div class="header-actions" id="header-actions">
    <button class="btn" id="load-new-btn" style="display:none" onclick="resetApp()">Load New Log</button>
    <span id="header-info" style="font-size:12px;color:var(--text2);font-family:var(--font-mono)"></span>
  </div>
</header>

<!-- LANDING -->
<div id="landing">
  <div class="drop-zone" id="drop-zone">
    <input type="file" id="file-input" accept=".txt,.log">
    <div class="drop-icon">⚔</div>
    <div class="drop-title">Drop your Combat Log</div>
    <div class="drop-sub">Drag &amp; drop WoWCombatLog.txt or click to browse</div>
    <span class="drop-hint">Interface &gt; Advanced &gt; Enable Advanced Combat Logging</span>
  </div>
  <div class="demo-link">
    No log file? <a onclick="loadDemo()">Load demo analysis</a> to see how it works.
  </div>
  <div class="feature-grid">
    <div class="feature-card">
      <div class="fc-label">DR Tracking</div>
      <div class="fc-desc">Detect diminishing returns violations and missed CC windows</div>
    </div>
    <div class="feature-card">
      <div class="fc-label">Cooldown Audit</div>
      <div class="fc-desc">Flag wasted major cooldowns and missed offensive windows</div>
    </div>
    <div class="feature-card">
      <div class="fc-label">Target AI</div>
      <div class="fc-desc">Identify bad swaps, tunnel vision, and win condition failures</div>
    </div>
  </div>
</div>

<!-- LOADING -->
<div id="loading-screen">
  <div style="font-family:var(--font-cond);font-size:18px;font-weight:700;letter-spacing:0.1em;color:var(--text1)">PARSING COMBAT LOG</div>
  <div class="loading-bar-wrap"><div class="loading-bar" id="loading-bar"></div></div>
  <div class="loading-text" id="loading-text">Initializing...</div>
</div>

<!-- APP -->
<div id="app">
  <div class="sidebar">
    <div class="sidebar-header">Solo Shuffle Rounds</div>
    <div id="rounds-list"></div>
    <div class="sidebar-summary" id="sidebar-summary"></div>
  </div>
  <div class="main-panel" id="main-panel">
    <div class="empty-state">Select a round from the sidebar to begin analysis.</div>
  </div>
</div>

<div class="tooltip" id="tooltip"></div>

<script>
// ============================================================
// COMBAT LOG PARSER
// ============================================================

const DR_CATEGORIES = {
  stun: ['CHEAPSHOT','KNEECAPPER','KIDNEY_SHOT','SHADOWSTEP','CHARGE_STUN','IMPACT','KIDNEY','CHEAP_SHOT','BASHING','BASH','HAMMER_OF_JUSTICE','WAR_STOMP','INTIMIDATION','STARFALL','MAIM','MIGHTY_BASH'],
  incapacitate: ['BLIND','SAP','GOUGE','HEX','FREEZING_TRAP','FREEZE','DRAGON_S_BREATH','POLYMORPH','REPENTANCE','MIND_CONTROL','TURN_EVIL'],
  disorient: ['FEAR','HOWL_OF_TERROR','PSYCHIC_SCREAM','INTIMIDATING_SHOUT','SEDUCTION','DEATH_COIL'],
  silence: ['SILENCE','COUNTERSPELL','KICK','PUMMEL','MIND_FREEZE','WIND_SHEAR','SOLAR_BEAM','REBUKE'],
  root: ['ENTANGLING_ROOTS','FROST_NOVA','FREEZE','EARTHBIND','CHAINS_OF_ICE','FROSTBITE']
};

const DR_DECAY = 18000; // 18 seconds in ms
const DR_HALF_THRESHOLDS = [1.0, 0.5, 0.25, 0.0]; // full, half, quarter, immune

const MAJOR_COOLDOWNS = {
  'AVENGING_WRATH': { name: 'Avenging Wrath', duration: 20000, type: 'offensive' },
  'COMBUSTION': { name: 'Combustion', duration: 12000, type: 'offensive' },
  'VENDETTA': { name: 'Vendetta', duration: 20000, type: 'offensive' },
  'WINGS': { name: 'Wings', duration: 20000, type: 'offensive' },
  'DARK_SOUL': { name: 'Dark Soul', duration: 20000, type: 'offensive' },
  'COLOSSUS_SMASH': { name: 'Colossus Smash', duration: 8000, type: 'offensive' },
  'SYMBOLS_OF_DEATH': { name: 'Symbols of Death', duration: 45000, type: 'offensive' },
  'RECKLESSNESS': { name: 'Recklessness', duration: 12000, type: 'offensive' },
  'INCARNATION': { name: 'Incarnation', duration: 30000, type: 'offensive' },
  'SHADOW_DANCE': { name: 'Shadow Dance', duration: 8000, type: 'offensive' },
  'BERSERKING': { name: 'Berserking', duration: 12000, type: 'offensive' },
  'ICEBLOCK': { name: 'Ice Block', duration: 10000, type: 'defensive' },
  'DIVINE_SHIELD': { name: 'Divine Shield', duration: 8000, type: 'defensive' },
  'EVASION': { name: 'Evasion', duration: 10000, type: 'defensive' },
  'BLUR': { name: 'Blur', duration: 10000, type: 'defensive' },
};

function parseCombatLog(text) {
  const lines = text.split('\n');
  const rounds = [];
  let currentRound = null;
  let roundIndex = 0;

  for (const line of lines) {
    if (!line.trim()) continue;
    const parts = line.split('  ');
    if (parts.length < 2) continue;

    const timestampStr = parts[0];
    const payload = parts.slice(1).join('  ');
    const timestamp = parseTimestamp(timestampStr);
    if (!timestamp) continue;

    const fields = payload.split(',');
    const eventType = fields[0];

    // Detect round start/end via ARENA_MATCH events or UNIT_DIED patterns
    if (eventType === 'ARENA_MATCH_START' || eventType === 'ZONE_CHANGE') {
      if (currentRound) rounds.push(finalizeRound(currentRound));
      roundIndex++;
      currentRound = createRound(roundIndex, timestamp, fields);
    } else if (eventType === 'ARENA_MATCH_END') {
      if (currentRound) {
        currentRound.endTime = timestamp;
        rounds.push(finalizeRound(currentRound));
        currentRound = null;
      }
    } else if (currentRound) {
      processEvent(currentRound, timestamp, eventType, fields, payload);
    }
  }

  if (currentRound) rounds.push(finalizeRound(currentRound));
  return rounds;
}

function parseTimestamp(ts) {
  // Format: M/D H:MM:SS.mmm
  const m = ts.match(/(\d+)\/(\d+)\s+(\d+):(\d+):(\d+)\.(\d+)/);
  if (!m) return null;
  return new Date(2024, m[1]-1, m[2], m[3], m[4], m[5], m[6]).getTime();
}

function createRound(idx, timestamp, fields) {
  return {
    index: idx,
    startTime: timestamp,
    endTime: null,
    players: {},
    events: [],
    drTracker: {},
    cooldownUsage: [],
    deaths: [],
    kills: [],
    winner: null,
    raw: fields
  };
}

function processEvent(round, ts, eventType, fields, payload) {
  const relTime = ts - round.startTime;

  // Track players
  const sourceGUID = fields[1] || '';
  const sourceName = (fields[2] || '').replace(/"/g,'');
  const destGUID   = fields[4] || '';
  const destName   = (fields[5] || '').replace(/"/g,'');
  const spellName  = (fields[10] || '').replace(/"/g,'');
  const spellNameUpper = spellName.toUpperCase().replace(/[\s']/g,'_');

  if (sourceGUID.startsWith('Player-') && sourceName) {
    if (!round.players[sourceGUID]) round.players[sourceGUID] = { name: sourceName, guid: sourceGUID, spec: 'Unknown', dmgOut: 0, ccApplied: 0, deathCount: 0 };
  }
  if (destGUID.startsWith('Player-') && destName) {
    if (!round.players[destGUID]) round.players[destGUID] = { name: destName, guid: destGUID, spec: 'Unknown', dmgOut: 0, ccApplied: 0, deathCount: 0 };
  }

  // SPELL_AURA_APPLIED — CC tracking
  if (eventType === 'SPELL_AURA_APPLIED' || eventType === 'SPELL_AURA_APPLIED_DOSE') {
    const drCat = getDRCategory(spellNameUpper);
    if (drCat && destGUID) {
      const key = `${destGUID}_${drCat}`;
      if (!round.drTracker[key]) round.drTracker[key] = [];
      const history = round.drTracker[key];
      const lastEntry = history[history.length - 1];
      let drMultiplier = 1.0;
      if (lastEntry && (ts - lastEntry.ts) < DR_DECAY) {
        drMultiplier = lastEntry.multiplier * 0.5;
      }

      const drEvent = { ts, relTime, spellName, sourceName, destName, category: drCat, multiplier: drMultiplier };
      history.push(drEvent);

      const flag = drMultiplier <= 0 ? '⚠ IMMUNE — wasted CC' : drMultiplier < 1 ? `DR: ${drMultiplier*100|0}% duration` : null;
      round.events.push({
        type: 'CC', relTime, source: sourceName, dest: destName,
        spell: spellName, drCategory: drCat, drMultiplier,
        desc: `${sourceName} → ${spellName} on ${destName}`,
        flag, positive: !flag && drMultiplier === 1.0 && null
      });

      if (round.players[sourceGUID]) round.players[sourceGUID].ccApplied++;
    }
  }

  // SPELL_CAST_SUCCESS — cooldown tracking
  if (eventType === 'SPELL_CAST_SUCCESS') {
    const cdDef = MAJOR_COOLDOWNS[spellNameUpper];
    if (cdDef) {
      round.cooldownUsage.push({ ts, relTime, sourceName, spellName: cdDef.name, type: cdDef.type, duration: cdDef.duration });
      round.events.push({
        type: 'COOLDOWN', relTime, source: sourceName, dest: destName || '',
        spell: cdDef.name, cdType: cdDef.type,
        desc: `${sourceName} used ${cdDef.name}`,
        flag: null
      });
    }
  }

  // UNIT_DIED
  if (eventType === 'UNIT_DIED') {
    const diedName = (fields[5] || '').replace(/"/g,'');
    round.deaths.push({ ts, relTime, name: diedName });
    round.events.push({ type: 'DEATH', relTime, source: diedName, dest: '', spell: '', desc: `${diedName} died`, flag: null });
    if (round.players[destGUID]) round.players[destGUID].deathCount++;
  }

  // SWING_DAMAGE / SPELL_DAMAGE for basic damage tracking
  if ((eventType === 'SWING_DAMAGE' || eventType === 'SPELL_DAMAGE') && round.players[sourceGUID]) {
    const amount = parseInt(fields[12]) || parseInt(fields[13]) || 0;
    round.players[sourceGUID].dmgOut += amount;
  }
}

function getDRCategory(spellNameUpper) {
  for (const [cat, spells] of Object.entries(DR_CATEGORIES)) {
    if (spells.some(s => spellNameUpper.includes(s))) return cat;
  }
  return null;
}

function finalizeRound(round) {
  // Sort events
  round.events.sort((a,b) => a.relTime - b.relTime);
  round.duration = round.endTime ? (round.endTime - round.startTime) : 0;
  round.mistakes = generateMistakeReport(round);
  round.score = calculateScore(round);
  return round;
}

function generateMistakeReport(round) {
  const mistakes = [];

  // DR violations
  for (const [key, history] of Object.entries(round.drTracker)) {
    for (const entry of history) {
      if (entry.multiplier <= 0) {
        mistakes.push({
          severity: 'HIGH',
          category: 'DR Violation',
          title: `Immune-state CC wasted (${entry.category})`,
          desc: `${entry.sourceName} cast ${entry.spellName} on ${entry.destName} while already immune from diminishing returns. This CC had 0% duration.`,
          tip: 'Wait for DR to reset (18 seconds after the last CC in this category expired) before reapplying.',
          at: fmtTime(entry.relTime)
        });
      } else if (entry.multiplier === 0.25) {
        mistakes.push({
          severity: 'MEDIUM',
          category: 'DR Violation',
          title: `Quarter-duration CC applied (${entry.category})`,
          desc: `${entry.sourceName} applied ${entry.spellName} at 25% duration. Consider letting DR decay before chaining.`,
          tip: 'Quarter-duration CCs rarely achieve kill pressure. Coordinate with teammates to reset DR or switch targets.',
          at: fmtTime(entry.relTime)
        });
      }
    }
  }

  // Detect cooldown dump without setup (major offensive CD without prior CC on target)
  const offCDs = round.cooldownUsage.filter(c => c.type === 'offensive');
  for (const cd of offCDs) {
    const nearbyCC = round.events.find(e =>
      e.type === 'CC' && Math.abs(e.relTime - cd.relTime) < 3000
    );
    if (!nearbyCC && round.events.filter(e => e.type === 'CC').length > 0) {
      mistakes.push({
        severity: 'MEDIUM',
        category: 'Cooldown Usage',
        title: `${cd.spellName} used without CC setup`,
        desc: `${cd.sourceName} activated ${cd.spellName} but no crowd control was applied within 3 seconds. Offensive CDs deal optimal pressure when the target is locked down.`,
        tip: 'Coordinate your burst window: CC first (or wait for a teammate CC), then activate offensive cooldowns to maximize pressure.',
        at: fmtTime(cd.relTime)
      });
    }
  }

  // Long periods without CC when multiple CCs available
  const ccEvents = round.events.filter(e => e.type === 'CC');
  if (ccEvents.length > 0 && round.duration > 30000) {
    let maxGap = 0;
    let gapStart = 0;
    let worstGap = null;
    for (let i = 1; i < ccEvents.length; i++) {
      const gap = ccEvents[i].relTime - ccEvents[i-1].relTime;
      if (gap > maxGap) { maxGap = gap; worstGap = { start: ccEvents[i-1].relTime, end: ccEvents[i].relTime }; }
    }
    if (maxGap > 20000) {
      mistakes.push({
        severity: 'LOW',
        category: 'Pressure',
        title: `${(maxGap/1000).toFixed(0)}s gap in crowd control`,
        desc: `Between ${fmtTime(worstGap.start)} and ${fmtTime(worstGap.end)}, no CC was applied. Extended periods without crowd control allow healers to recover freely.`,
        tip: 'Against a healer, aim for a continuous CC chain using different DR categories. Rotate stuns, incapacitates, and silences to maintain pressure.',
        at: fmtTime(worstGap.start)
      });
    }
  }

  // No cooldowns used in a long round
  if (round.duration > 45000 && round.cooldownUsage.length === 0) {
    mistakes.push({
      severity: 'HIGH',
      category: 'Cooldown Usage',
      title: 'No major cooldowns used',
      desc: `The round lasted over 45 seconds and no tracked major offensive/defensive cooldowns were detected. This likely indicates cooldowns were saved indefinitely.`,
      tip: 'Major cooldowns are almost always worth using in Solo Shuffle rounds. If you are saving them, have a clear reason (e.g., enemy Divine Shield just ended).',
      at: '0:00'
    });
  }

  mistakes.sort((a,b) => {
    const order = { HIGH:0, MEDIUM:1, LOW:2 };
    return order[a.severity] - order[b.severity];
  });

  return mistakes;
}

function calculateScore(round) {
  let score = 85;
  for (const m of round.mistakes) {
    if (m.severity === 'HIGH')   score -= 15;
    if (m.severity === 'MEDIUM') score -= 8;
    if (m.severity === 'LOW')    score -= 4;
  }
  return Math.max(0, Math.min(100, score));
}

function fmtTime(ms) {
  const s = Math.floor(ms / 1000);
  return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`;
}

