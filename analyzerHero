function loadDemo() {
  showLoading();
  let progress = 0;
  const steps = ['Loading demo data...', 'Reconstructing event timeline...', 'Running DR analysis...', 'Grading cooldown usage...', 'Generating reports...'];
  let step = 0;
  const interval = setInterval(() => {
    progress += 18 + Math.random() * 8;
    if (progress > 100) progress = 100;
    document.getElementById('loading-bar').style.width = progress + '%';
    document.getElementById('loading-text').textContent = steps[Math.min(step++, steps.length-1)];
    if (progress >= 100) {
      clearInterval(interval);
      setTimeout(() => {
        rounds = generateDemoRounds();
        showApp();
        renderSidebar();
        renderRound(rounds[0]);
        document.getElementById('header-info').textContent = 'Demo · 6 rounds · Krevash (Sub Rogue)';
      }, 300);
    }
  }, 150);
}

function showLoading() {
  document.getElementById('landing').style.display = 'none';
  document.getElementById('loading-screen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
  document.getElementById('app').classList.remove('visible');
}

function showApp() {
  document.getElementById('loading-screen').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
  document.getElementById('app').classList.add('visible');
  document.getElementById('load-new-btn').style.display = '';
}

function resetApp() {
  rounds = [];
  document.getElementById('landing').style.display = '';
  document.getElementById('app').style.display = 'none';
  document.getElementById('app').classList.remove('visible');
  document.getElementById('load-new-btn').style.display = 'none';
  document.getElementById('header-info').textContent = '';
}

// Real file parsing
document.getElementById('file-input').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  showLoading();
  const reader = new FileReader();
  reader.onload = function(ev) {
    document.getElementById('loading-text').textContent = 'Reading file...';
    document.getElementById('loading-bar').style.width = '30%';
    setTimeout(() => {
      try {
        document.getElementById('loading-text').textContent = 'Parsing combat events...';
        document.getElementById('loading-bar').style.width = '60%';
        setTimeout(() => {
          rounds = parseCombatLog(ev.target.result);
          document.getElementById('loading-text').textContent = 'Analyzing decisions...';
          document.getElementById('loading-bar').style.width = '85%';
          setTimeout(() => {
            document.getElementById('loading-bar').style.width = '100%';
            if (rounds.length === 0) {
              // No ARENA_MATCH events found — generate from events in file
              alert('No arena match markers found in log. The parser found the file but could not detect round boundaries. Try enabling "Advanced Combat Logging" (Interface > Advanced) and re-running a match.');
              resetApp();
              return;
            }
            showApp();
            renderSidebar();
            renderRound(rounds[0]);
            document.getElementById('header-info').textContent = `${file.name} · ${rounds.length} rounds detected`;
          }, 300);
        }, 400);
      } catch(err) {
        alert('Error parsing log: ' + err.message);
        resetApp();
      }
    }, 200);
  };
  reader.readAsText(file);
});

// Drag and drop
const dz = document.getElementById('drop-zone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
dz.addEventListener('drop', e => {
  e.preventDefault();
  dz.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file) {
    document.getElementById('file-input').files = e.dataTransfer.files;
    document.getElementById('file-input').dispatchEvent(new Event('change'));
  }
});
</script>
